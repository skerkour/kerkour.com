{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/",
      ".git*"
    ],
    "rewrites": [
    ],
    "headers": [
      {
        "source" : "**",
        "headers" : [
          {
            "key" : "X-XSS-Protection",
            "value" : "1; mode=block"
          },
          {
            "key" : "X-Content-Type-Options",
            "value" : "nosniff"
          },
          {
            "key" : "X-Download-Options",
            "value" : "noopen"
          },
          {
            "key" : "X-Frame-Options",
            "value" : "DENY"
          },
          {
            "key" : "X-DNS-Prefetch-Control",
            "value" : "off"
          },
          {
            "key" : "Referrer-Policy",
            "value" : "same-origin"
          },
          {
            "key" : "Expect-CT",
            "value" : "max-age=86400; enforce"
          }
        ]
      }
    ]
  }
}
